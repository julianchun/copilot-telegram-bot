# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id

# Workspace Configuration
# Main workspace folder - projects are subfolders under this path
WORKSPACE_ROOT=/Users/chun/workspace

# Granted Projects (Optional)
# Comma-separated list of additional project paths outside WORKSPACE_ROOT
# These will appear in the project selection menu alongside workspace projects
# Example: GRANTED_PROJECTS=/path/to/project1,/path/to/project2,/home/user/another/project
GRANTED_PROJECTS=

# GitHub Authentication (Optional)
# If not provided, uses GitHub CLI auth (requires: copilot auth)
# Useful for containerized deployments where CLI auth is difficult
GITHUB_TOKEN=

# Path to MCP Definition File (Optional)
# If not provided, uses Path.home() / ".copilot" / "mcp-config.json" File
MCP_CONFIG_PATH=
